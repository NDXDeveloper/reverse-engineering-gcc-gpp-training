# ===========================================================================
#  .gitignore — Reverse Engineering Training (GCC/G++)
#
#  Strategy: ignore EVERYTHING in binaries/ then re-include
#  only sources, Makefiles and config files.
#  This is the most robust method — any newly compiled binary
#  will be automatically ignored.
# ===========================================================================

# ── BINARIES: ignore all then re-include sources ────────────────────────

# Step 1: ignore everything in binaries/
binaries/**

# Step 2: re-include directories (required for traversal)
!binaries/
!binaries/*/
!binaries/**/

# Step 3: re-include source and config files
!binaries/Makefile
!binaries/*/Makefile
!binaries/**/*.c
!binaries/**/*.cpp
!binaries/**/*.h
!binaries/**/*.cs
!binaries/**/*.csproj
!binaries/**/*.rs
!binaries/**/*.go
!binaries/**/go.mod
!binaries/**/go.sum
!binaries/**/Cargo.toml
!binaries/**/Cargo.lock
!binaries/**/*.json
!binaries/**/*.md

# ── .locked files produced by the ransomware (ch27) ─────────────────────
*.locked
README_LOCKED.txt

# ── .NET (obj, bin, NuGet caches) — in case re-included by mistake ─────
**/obj/
**/bin/Release/
**/bin/Debug/

# ── Rust ─────────────────────────────────────────────────────────────────
**/target/

# ── Python ───────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.mypy_cache/
.pytest_cache/
*.egg-info/
venv/
.venv/

# ── Editors and IDEs ────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── GDB ──────────────────────────────────────────────────────────────────
.gdb_history
core
core.*

# ── Ghidra (local projects) ─────────────────────────────────────────────
*.gpr
*.rep/

# ── ImHex (local projects) ──────────────────────────────────────────────
*.hexproj

# ── Network captures ────────────────────────────────────────────────────
*.pcap
*.pcapng

# ── Sample archives (malware analysis convention) ───────────────────────
*.zip.malware
*.infected
